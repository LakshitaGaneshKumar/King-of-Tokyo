<!--        android:id="@+id/message_box"-->
<!--        android:layout_width="wrap_content"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:textSize="24sp"-->
<!--        android:text="@string/begin_game_text"-->
<!--        >-->

<!--    </TextView>-->

<!--THIS IS FOR HOMEWORK 1-->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        >

        <ImageButton
            android:id="@+id/btnClockwise"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/button_circle"
            android:src="@drawable/ic_clockwise"
            android:contentDescription="Clockwise" />

        <ImageButton
            android:id="@+id/btnCounterClockwise"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/button_circle"
            android:src="@drawable/ic_counter_clockwise"
            android:contentDescription="Counter Clockwise" />


        <ImageView
            android:id="@+id/clockwise"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/rot_clockwise">
        </ImageView>

        <ImageView
            android:id="@+id/counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/rot_counter">
        </ImageView>

    </LinearLayout>

</LinearLayout>