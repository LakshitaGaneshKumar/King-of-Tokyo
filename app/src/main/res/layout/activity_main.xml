<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:orientation="vertical"
    android:gravity="top|center_horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<!--    first, you should change the IDs after you drag and drop in the image views-->
<!--    we also got rid of the weight, which was set to 1 by default-->
    <ImageView
        android:id="@+id/yellow_robot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/robot_yellow_large" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/red_robot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/robot_red_large" />

        <ImageView
            android:id="@+id/white_robot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/robot_white_large" />

    </LinearLayout>

<!--    wrap_content = as big as it needs to be-->
<!--    match_parent = match the parent-->
<!--    fixed = fixed size-->
<!--    dp vs sp for fontSize - it should be sp for textSize, dp for everything else-->
<!--    we have to manually add the id in if we don't use drag and drop. we also have to wire up the message box on the kt file-->


    <!--THIS IS FROM CLASS-->
