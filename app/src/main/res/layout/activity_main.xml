<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- TOP PLAYER AREA -->
    <FrameLayout
        android:id="@+id/player_top_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/yellow_robot_card"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/die_unkept_background">

            <ImageView
                android:id="@+id/yellow_robot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/robot_yellow_large"
                android:contentDescription="@string/yellow_robot"/>

            <TextView
                android:id="@+id/yellow_robot_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/yellow_robot"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/yellow_robot_health"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/robot_health"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/yellow_robot_energy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/robot_energy"/>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- MIDDLE GAME BOARD AREA -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@android:color/black">

            <TextView
                android:id="@+id/tokyo_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tokyo"
                android:textColor="@android:color/white"
                android:textSize="48sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tokyo_occupant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tokyo_occupant"
                android:textColor="@android:color/white"/>

            <TextView
                android:id="@+id/message_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/begin_game_text"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center"/>

        </LinearLayout>

    </FrameLayout>

    <!-- BOTTOM PLAYERS AREA (2 PLAYERS SIDE BY SIDE) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- LEFT PLAYER (Player 2) -->
        <FrameLayout
            android:id="@+id/player_left_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp">

            <LinearLayout
                android:id="@+id/red_robot_card"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/die_unkept_background">

                <ImageView
                    android:id="@+id/red_robot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:srcCompat="@drawable/robot_red_large"
                    android:contentDescription="@string/red_robot"/>

                <TextView
                    android:id="@+id/red_robot_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/red_robot"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/red_robot_health"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/robot_health"/>

                <TextView
                    android:id="@+id/player2_energy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/robot_energy"/>

            </LinearLayout>

        </FrameLayout>

        <!-- RIGHT PLAYER (Player 3) -->
        <FrameLayout
            android:id="@+id/player_right_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp">

            <LinearLayout
                android:id="@+id/white_robot_card"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/die_unkept_background">

                <ImageView
                    android:id="@+id/white_robot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:srcCompat="@drawable/robot_white_large"
                    android:contentDescription="@string/white_robot"/>

                <TextView
                    android:id="@+id/white_robot_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/white_robot"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/white_robot_health"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/robot_health"/>

                <TextView
                    android:id="@+id/white_robot_energy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/robot_energy"/>

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- GAME CONTROLS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp">

        <Button
            android:id="@+id/roll_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Roll Dice"/>

        <Button
            android:id="@+id/purchase_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Purchase Reward"/>

    </LinearLayout>

</LinearLayout>