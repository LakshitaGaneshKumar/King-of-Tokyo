<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <TextView
            android:id="@+id/roll_dice_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roll Dice"
            android:textColor="@color/black"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:background="@drawable/die_unkept_background"
            android:gravity="center">

            <ImageView
                android:id="@+id/roll_dice_robot_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/robot_red_large"
                android:contentDescription="@string/red_robot"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/roll_dice_robot_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/red_message_text"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/roll_count_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Roll 1 of 3"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/roll_instruction_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Yahtzee-style rolling: tap dice to keep them, then roll again. You can roll up to 3 times."
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textAlignment="center"/>

        <GridLayout
            android:id="@+id/dice_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:columnCount="3"
            android:rowCount="2"
            android:useDefaultMargins="true"
            android:alignmentMode="alignMargins">

            <TextView
                android:id="@+id/die_1"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_columnWeight="1"
                android:background="@drawable/die_unkept_background"
                android:gravity="center"
                android:text="1"
                android:textSize="34sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/die_2"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_columnWeight="1"
                android:background="@drawable/die_unkept_background"
                android:gravity="center"
                android:text="2"
                android:textSize="34sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/die_3"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_columnWeight="1"
                android:background="@drawable/die_unkept_background"
                android:gravity="center"
                android:text="3"
                android:textSize="34sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/die_4"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_columnWeight="1"
                android:background="@drawable/die_unkept_background"
                android:gravity="center"
                android:text="⚡"
                android:textSize="34sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/die_5"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_columnWeight="1"
                android:background="@drawable/die_unkept_background"
                android:gravity="center"
                android:text="❤"
                android:textSize="34sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/die_6"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_columnWeight="1"
                android:background="@drawable/die_unkept_background"
                android:gravity="center"
                android:text="💥"
                android:textSize="34sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/roll_again_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Roll Remaining Dice"/>

            <Button
                android:id="@+id/roll_done_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Done"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>