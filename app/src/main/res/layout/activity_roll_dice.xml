<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp"
    android:background="@color/black">

    <!-- Current robot image and turn label -->
    <ImageView
        android:id="@+id/roll_dice_robot_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/robot_red_large"
        android:contentDescription="@string/red_robot"/>

    <TextView
        android:id="@+id/roll_dice_robot_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/red_message_text"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"/>

    <!-- Dice grid: 2 columns x 3 rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/die_1"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_margin="6dp"
            android:text="1"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@android:color/white"/>

        <TextView
            android:id="@+id/die_2"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_margin="6dp"
            android:text="2"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@android:color/white"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/die_3"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_margin="6dp"
            android:text="3"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@android:color/white"/>

        <TextView
            android:id="@+id/die_4"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_margin="6dp"
            android:text="⚡"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@android:color/white"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/die_5"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_margin="6dp"
            android:text="❤"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@android:color/white"/>

        <TextView
            android:id="@+id/die_6"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_margin="6dp"
            android:text="💥"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@android:color/white"/>

    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/roll_again_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Roll Again"/>

        <Button
            android:id="@+id/roll_done_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Done"/>

    </LinearLayout>

</LinearLayout>